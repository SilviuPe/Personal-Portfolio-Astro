---
import "../styles/global.css";
import Header from '../components/Header.jsx';
import Footer from '../components/Footer';
import DeveloperSection from '../components/DeveloperSection.jsx';
const { title = "Silvyu Dev" } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/faviconme.png" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <Header page="About" client:load />
        <DeveloperSection client:load />
        <Footer page="About" client:load/>
        <script is:inline>
            if ("scrollRestoration" in history) {
                history.scrollRestoration = "manual";
            }

            window.addEventListener("load", () => {
                window.scrollTo(0, 0);
            });
        </script>
    </body>
</html>
