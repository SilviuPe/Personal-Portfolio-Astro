---
import "../styles/global.css";
import "../styles/home.css";

import Header from '../components/Header.jsx';
import Hero from '../components/Hero.jsx';
import Reviews from '../components/Reviews.jsx';
import Footer from '../components/Footer.jsx';
import Services from '../components/ServicesQuality';
import ProjectsList from '../components/ProjectsList';
import ContactComponent from '../components/Contact';

const { title = "Silvyu Dev" } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/faviconme.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>

	<body>
		<Header page="Home" client:load />
		<Hero client:load />
		<Reviews client:load />
		<Services client:load />
		<ProjectsList customTitle={undefined} exceptProject={undefined} client:load />
		<ContactComponent client:load/>
		<Footer page="Home" client:load/>
		<script is:inline>
			if ("scrollRestoration" in history) {
				history.scrollRestoration = "manual";
			}

			window.addEventListener("load", () => {
				window.scrollTo(0, 0);
			});
		</script>
	</body>
</html>